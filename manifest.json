{
  "manifest_version": 3,
  "name": "WISO Steuer CSV Import",
  "version": "1.0.0",
  "description": "Import CSV data into WISO Steuer tables",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.buhl.de/*", "*://*.wiso-steuer.de/*"],
      "js": ["csv-parser.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["*://*.buhl.de/*", "*://*.wiso-steuer.de/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
